# Reverse proxy for The Last Quiz (Caddy v2 — automatic HTTPS via Let's Encrypt).
#
# Both public subdomains proxy to the SAME FastAPI backend. The app is
# Host-aware: rankings.<domain> serves the public rankings page at its root,
# and app.<domain> serves the main app (and /admin). Caddy forwards the
# original Host header by default, which the app relies on to route.
#
# NOTE ON DOMAIN: you created "thelastquiz.net" but wrote the subdomains as
# "app.lastquiz.net" / "rankings.lastquiz.net" (missing the "the"). Pick one
# consistent apex domain and use it in both DNS and here. This file assumes
# thelastquiz.net — change it if you meant lastquiz.net.
#
# DNS: point A/AAAA records for both subdomains at this server's IP.
#
# Run the backend behind this proxy with forwarded headers trusted:
#   LLM_POP_QUIZ_ENV=real OPENROUTER_API_KEY=sk-... \
#     .venv/bin/uvicorn llm_pop_quiz_bench.api.app:app \
#       --host 127.0.0.1 --port 8000 \
#       --proxy-headers --forwarded-allow-ips="*"
#
# If you gate the admin console, also set LLM_POP_QUIZ_ADMIN_TOKEN=... and send
# it as the X-Admin-Token header (the admin page has a field for it).

app.thelastquiz.net, rankings.thelastquiz.net {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8000
}

# Optional: redirect the bare apex to the app (or the rankings site — your call).
# thelastquiz.net {
# 	redir https://app.thelastquiz.net{uri}
# }
